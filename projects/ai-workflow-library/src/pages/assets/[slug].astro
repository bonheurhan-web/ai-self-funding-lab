---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { assets, type Asset } from "../../data/assets";

export function getStaticPaths() {
  return assets.map((asset) => ({
    params: { slug: asset.slug },
    props: { asset },
  }));
}

type Props = {
  asset: Asset;
};

const { asset } = Astro.props;
---

<BaseLayout
  title={`${asset.title} | AI Workflow Library`}
  description={`${asset.purpose} Format: ${asset.format}.`}
>
  <article class="asset-detail">
    <p class="eyebrow">{asset.id} / Template summary</p>
    <h1>{asset.title}</h1>

    <dl class="facts">
      <div class="fact">
        <dt>Purpose</dt>
        <dd>{asset.purpose}</dd>
      </div>
      <div class="fact">
        <dt>Format</dt>
        <dd>{asset.format}</dd>
      </div>
    </dl>

    <div class="notice">
      <strong>Current status</strong>
      <p>Payment link pending approval. No automatic delivery is active.</p>
    </div>

    <div class="actions">
      <a class="button secondary" href="/">Back to home</a>
      <a class="button" href="/#starter-pack">View the $5 pack</a>
    </div>
  </article>
</BaseLayout>
