---
import BaseLayout from "../layouts/BaseLayout.astro";
import { assets } from "../data/assets";

const supportUrl = import.meta.env.PAYPAL_SUPPORT_URL?.trim();
const buyUrl = import.meta.env.PAYPAL_BUY_URL?.trim();
const affiliateLink = import.meta.env.AFFILIATE_LINK?.trim();
const paymentPending = "Payment link pending approval.";
---

<BaseLayout
  title="AI Workflow Library | $5 starter templates for AI projects"
  description="A minimal $5 template pack for copying a clear AI project structure with Codex, ChatGPT, and simple revenue tracking."
>
  <section class="hero">
    <p class="eyebrow">AI Workflow Library · 图书馆</p>
    <h1>Copy a simple AI project system for $5.</h1>
    <p class="lede">
      Get five practical templates for briefing Codex, starting an AI project, tracking revenue, running daily work, and deciding when to stop.
    </p>
    <p class="translation" lang="zh-CN">
      图书馆是一组极简 AI 项目模板，帮助你快速复制项目结构、执行流程和复盘方式。
    </p>
    <div class="actions">
      <a class="button" href="#starter-pack">View the $5 pack</a>
      <a class="button secondary" href="#assets">See the templates</a>
    </div>
  </section>

  <section class="section" id="starter-pack">
    <div class="offer">
      <div>
        <p class="eyebrow">Minimum paid offer</p>
        <h2>AI Self-Funding Starter Pack</h2>
        <p>
          Price: <strong>5 USD</strong>. You get five core templates that help you copy a clear AI project structure without a database, login system, or complex tooling.
        </p>
        <ul>
          {assets.map((asset) => <li>{asset.title}</li>)}
        </ul>
        <p class="muted">
          Current status: PayPal is under review. Payment is not available yet.
        </p>
        <p class="muted" lang="zh-CN">
          当前状态：PayPal 正在审核，暂时不可支付。
        </p>
        <div class="actions">
          {
            buyUrl ? (
              <a class="button" href={buyUrl} rel="nofollow">Buy with PayPal</a>
            ) : (
              <span class="button disabled" aria-disabled="true">{paymentPending}</span>
            )
          }
          {
            supportUrl ? (
              <a class="button secondary" href={supportUrl} rel="nofollow">Support with PayPal</a>
            ) : (
              <span class="button disabled" aria-disabled="true">{paymentPending}</span>
            )
          }
        </div>
      </div>
      <div>
        <p class="price">$5</p>
        <p class="muted">One-time template pack. No subscription.</p>
      </div>
    </div>
  </section>

  <section class="section" id="assets">
    <div class="section-heading">
      <div>
        <p class="eyebrow">The five templates</p>
        <h2>Short, usable, and focused.</h2>
      </div>
      <p>
        Each template has one job: make an AI-assisted project easier to start, run, measure, or stop.
      </p>
    </div>
    <div class="grid">
      {
        assets.map((asset) => (
          <article class="card">
            <p class="id">{asset.id}</p>
            <h3>{asset.title}</h3>
            <p>{asset.purpose}</p>
            <p class="muted">Format: {asset.format}</p>
            <a href={`/assets/${asset.slug}/`}>View summary</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" id="free-downloads">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Free preview</p>
        <h2>Free downloads are placeholders.</h2>
      </div>
      <p>
        Preview files will be added only after manual review. No automatic delivery is active.
      </p>
    </div>
    <span class="button disabled" aria-disabled="true">Free preview pending review</span>
  </section>

  <section class="section">
    <div class="grid">
      <article class="card">
        <p class="eyebrow">Affiliate placeholder</p>
        <h3>Recommended tools</h3>
        <p>No affiliate recommendation is active yet.</p>
        {
          affiliateLink ? (
            <a class="button secondary" href={affiliateLink} rel="nofollow">View tool</a>
          ) : (
            <span class="button disabled" aria-disabled="true">Affiliate link pending review</span>
          )
        }
      </article>
      <article class="card">
        <p class="eyebrow">Risk statement</p>
        <h3>No income guarantee</h3>
        <p>This is an experimental system. It does not guarantee income.</p>
        <p lang="zh-CN">这是一个实验系统，不保证产生收入。</p>
      </article>
    </div>
  </section>
</BaseLayout>
