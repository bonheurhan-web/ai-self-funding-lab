---
import BaseLayout from "../layouts/BaseLayout.astro";
import { assets } from "../data/assets";

const supportUrl = import.meta.env.PAYPAL_SUPPORT_URL?.trim();
const buyUrl = import.meta.env.PAYPAL_BUY_URL?.trim();
const affiliateDisclosure = import.meta.env.AFFILIATE_DISCLOSURE?.trim();
const paymentPending = "Payment link pending approval.";
---

<BaseLayout
  title="AI Workflow Library | Reusable systems for AI-assisted work"
  description="Practical templates and operating systems for running measurable projects with ChatGPT, Codex, and other AI tools."
>
  <section class="hero">
    <p class="eyebrow">An open revenue experiment · 一个公开的收入实验</p>
    <h1>Make AI work like a system.</h1>
    <p class="lede">
      The AI Workflow Library turns a real experiment in directing ChatGPT and Codex like project
      operators into reusable templates, checklists, and operating systems.
    </p>
    <p class="translation" lang="zh-CN">
      图书馆把“如何指挥 ChatGPT + Codex 像员工一样做项目赚钱”的真实实验过程，整理成模板、清单和操作系统。
    </p>
    <div class="actions">
      <a class="button" href="#starter-pack">See the $5 starter pack</a>
      <a class="button secondary" href="#free-downloads">Explore free resources</a>
    </div>
  </section>

  <section class="section" id="assets">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Launch collection</p>
        <h2>Five assets for running focused AI experiments.</h2>
      </div>
      <p class="translation" lang="zh-CN">
        首发内容覆盖项目指挥、启动、指标、日常执行和停止条件。当前提供摘要，完整交付将在付款与审核流程确认后决定。
      </p>
    </div>
    <div class="grid">
      {
        assets.map((asset, index) => (
          <article class:list={["card", { featured: index === 0 }]}>
            <p class="id">{asset.id}</p>
            <h3>{asset.title}</h3>
            <p lang="zh-CN">{asset.titleZh}</p>
            <p>{asset.problem}</p>
            <a href={`/assets/${asset.slug}/`}>View asset summary →</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" id="starter-pack">
    <div class="offer">
      <div>
        <p class="eyebrow">Proposed paid bundle</p>
        <h2>AI Self-Funding Starter Pack</h2>
        <p>
          Five complete templates, a usage guide, a 7-day experiment plan, a project review sheet,
          and a practical Codex command collection.
        </p>
        <p class="muted" lang="zh-CN">
          计划包含 5 个完整模板、使用说明、7 天实验计划、项目复盘表和 Codex 指令合集。
        </p>
        <div class="actions">
          {
            buyUrl ? (
              <a class="button" href={buyUrl} rel="nofollow">Buy with PayPal</a>
            ) : (
              <span class="button disabled" aria-disabled="true">{paymentPending}</span>
            )
          }
        </div>
        <p class="muted">
          No automatic delivery is promised. The final payment and delivery flow will be confirmed
          after PayPal review.
        </p>
      </div>
      <div>
        <p class="price">$5</p>
        <p class="muted">One-time proposed price. No subscription.</p>
      </div>
    </div>
  </section>

  <section class="section" id="free-downloads">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Free downloads</p>
        <h2>Start with the public versions.</h2>
      </div>
      <p>
        Download files are being prepared. This area will remain a placeholder until the content and
        delivery method pass review.
      </p>
    </div>
    <span class="button disabled" aria-disabled="true">Free downloads coming soon</span>
  </section>

  <section class="section">
    <div class="grid">
      <article class="card">
        <p class="eyebrow">Support the experiment</p>
        <h3>PayPal support</h3>
        <p>Optional support helps fund further testing and documentation.</p>
        {
          supportUrl ? (
            <a class="button" href={supportUrl} rel="nofollow">Support with PayPal</a>
          ) : (
            <span class="button disabled" aria-disabled="true">{paymentPending}</span>
          )
        }
      </article>
      <article class="card">
        <p class="eyebrow">Affiliate disclosure</p>
        <h3>Recommended tools</h3>
        <p>
          {affiliateDisclosure || "Affiliate recommendations are not active. Any future affiliate relationship will be disclosed clearly."}
        </p>
        <span class="button disabled" aria-disabled="true">Affiliate links pending review</span>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="notice">
      <strong>Risk statement</strong>
      <p>This is an experiment system. It does not guarantee income.</p>
      <p lang="zh-CN">这是一个实验系统，不保证产生收入。</p>
    </div>
  </section>
</BaseLayout>
