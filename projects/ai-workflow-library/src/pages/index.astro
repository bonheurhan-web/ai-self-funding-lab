---
import BaseLayout from "../layouts/BaseLayout.astro";
import { assets } from "../data/assets";

const supportUrl = import.meta.env.PAYPAL_SUPPORT_URL?.trim();
const buyUrl = import.meta.env.PAYPAL_BUY_URL?.trim();
const affiliateLink = import.meta.env.AFFILIATE_LINK?.trim();
const paymentPending = "Payment link pending approval.";
---

<BaseLayout
  title="AI Workflow Library | Copy the AI self-funding workflow"
  description="A $5 copy-paste workflow system for running small AI revenue experiments with Codex and ChatGPT."
>
  <section class="hero">
    <p class="eyebrow">AI Workflow Library / 图书馆</p>
    <h1>I built a system that tries to make AI earn money.</h1>
    <p class="lede">
      This is the exact structure I use: Codex instructions, project templates, workflow checklists, and experiment tracking.
    </p>
    <p class="translation" lang="zh-CN">
      这是一个 AI 自养实验系统。你可以复制这套结构，用来启动、执行和复盘自己的 AI 项目。
    </p>
    <div class="actions">
      <a class="button" href="#starter-pack">Get the $5 system</a>
      <a class="button secondary" href="#included">See what is included</a>
    </div>
  </section>

  <section class="section">
    <div class="grid">
      <article class="card">
        <h3>Not theory</h3>
        <p>A real structure used to run an AI revenue experiment.</p>
      </article>
      <article class="card">
        <h3>Not ideas</h3>
        <p>Copy-paste files, checklists, and instructions.</p>
      </article>
      <article class="card">
        <h3>Real experiment system</h3>
        <p>Built to track actions, costs, revenue, and stop decisions.</p>
      </article>
    </div>
  </section>

  <section class="section" id="starter-pack">
    <div class="offer">
      <div>
        <p class="eyebrow">Low-friction offer</p>
        <h2>One coffee ($5) = full AI workflow system</h2>
        <p>
          A copyable starter system for turning a vague AI project idea into a structured experiment.
          It is designed to be used immediately, without a database, login, subscription, or long setup.
        </p>
        <p class="muted" lang="zh-CN">
          一杯咖啡的价格，拿到一套可复制的 AI 项目工作流。当前 PayPal 正在审核，暂时不可支付。
        </p>
        <div class="actions">
          {
            buyUrl ? (
              <a class="button" href={buyUrl} rel="nofollow">Support this experiment ($5)</a>
            ) : (
              <span class="button disabled" aria-disabled="true">{paymentPending}</span>
            )
          }
          {
            supportUrl ? (
              <a class="button secondary" href={supportUrl} rel="nofollow">Support this experiment ($5)</a>
            ) : (
              <span class="button disabled" aria-disabled="true">{paymentPending}</span>
            )
          }
        </div>
        <p class="muted">PayPal is under review. No real payment link is active yet.</p>
      </div>
      <div>
        <p class="price">$5</p>
        <p class="muted">One-time support. No subscription.</p>
      </div>
    </div>
  </section>

  <section class="section" id="included">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Use immediately</p>
        <h2>What you can copy and use.</h2>
      </div>
      <p>
        The pack is built for low learning cost: open the files, copy the structure, and adapt it to your own AI project.
      </p>
    </div>
    <div class="grid">
      <article class="card">
        <h3>Copy-paste Codex instructions</h3>
        <p>Tell Codex what to do, what not to do, and how to report completion.</p>
      </article>
      <article class="card">
        <h3>AI project structure templates</h3>
        <p>Start with a clear project brief, scope, approval rules, and review date.</p>
      </article>
      <article class="card">
        <h3>Workflow checklist</h3>
        <p>Run daily AI work without turning it into scattered conversations.</p>
      </article>
      <article class="card">
        <h3>Experiment tracking system</h3>
        <p>Track cost, revenue, status, and the decision to continue or stop.</p>
      </article>
    </div>
  </section>

  <section class="section" id="assets">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Five core templates</p>
        <h2>Everything stays short.</h2>
      </div>
      <p>Each asset has one purpose and one clear format.</p>
    </div>
    <div class="grid">
      {
        assets.map((asset) => (
          <article class="card">
            <p class="id">{asset.id}</p>
            <h3>{asset.title}</h3>
            <p>{asset.purpose}</p>
            <p class="muted">Format: {asset.format}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">FAQ</p>
        <h2>Before you support it.</h2>
      </div>
      <p class="muted">Short answers only.</p>
    </div>
    <div class="grid">
      <article class="card">
        <h3>Do I need programming skills?</h3>
        <p>No. The templates are written for copy-paste use with Codex, ChatGPT, or similar AI tools.</p>
      </article>
      <article class="card">
        <h3>Does it guarantee income?</h3>
        <p>No. This is an experiment system. No income guarantee.</p>
      </article>
      <article class="card">
        <h3>Can I use it immediately?</h3>
        <p>Yes. The structure is meant to be copied, edited, and used immediately.</p>
      </article>
    </div>
  </section>

  <section class="section" id="free-downloads">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Preview status</p>
        <h2>Downloads and payment are placeholders.</h2>
      </div>
      <p>
        PayPal is still under review. Preview files will be added only after manual review.
      </p>
    </div>
    <span class="button disabled" aria-disabled="true">Payment link pending approval.</span>
  </section>

  <section class="section">
    <div class="grid">
      <article class="card">
        <p class="eyebrow">Affiliate placeholder</p>
        <h3>Recommended tools</h3>
        <p>No affiliate recommendation is active yet.</p>
        {
          affiliateLink ? (
            <a class="button secondary" href={affiliateLink} rel="nofollow">View tool</a>
          ) : (
            <span class="button disabled" aria-disabled="true">Affiliate link pending review</span>
          )
        }
      </article>
      <article class="card">
        <p class="eyebrow">Risk statement</p>
        <h3>No income guarantee</h3>
        <p>This is an experiment system. No income guarantee.</p>
        <p lang="zh-CN">这是一个实验系统，不保证产生收入。</p>
      </article>
    </div>
  </section>
</BaseLayout>
