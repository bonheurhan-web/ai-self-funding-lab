---
type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">AI Workflow Library <span>图书馆</span></a>
      <a href="/#starter-pack">Starter Pack · $5</a>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Built as an AI Self-Funding Lab revenue experiment.</p>
      <p lang="zh-CN">这是 AI Self-Funding Lab 的收入验证实验。</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color: #182018;
    background: #f4f0e6;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-synthesis: none;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 8% 3%, rgba(211, 229, 193, 0.7), transparent 30rem),
      #f4f0e6;
  }

  a {
    color: inherit;
  }

  .site-header,
  main,
  footer {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-bottom: 1px solid #b9b8aa;
    font-size: 0.9rem;
  }

  .site-header a {
    text-decoration: none;
  }

  .brand {
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .brand span {
    color: #58744e;
    font-weight: 600;
  }

  main {
    min-height: 75vh;
  }

  .hero {
    padding: 7rem 0 5rem;
    max-width: 920px;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: #51684a;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 1.5rem;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3.2rem, 9vw, 7.5rem);
    line-height: 0.9;
    letter-spacing: -0.065em;
  }

  h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4vw, 3.7rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  h3 {
    font-size: 1.15rem;
  }

  .lede {
    max-width: 700px;
    color: #455044;
    font-size: clamp(1.1rem, 2.4vw, 1.45rem);
    line-height: 1.55;
  }

  .translation {
    color: #687266;
    line-height: 1.7;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.75rem 1rem;
    border: 1px solid #182018;
    border-radius: 999px;
    background: #182018;
    color: #fff;
    font-weight: 750;
    text-decoration: none;
  }

  .button.secondary {
    background: transparent;
    color: #182018;
  }

  .button.disabled {
    border-color: #aaa99d;
    background: #dedbd0;
    color: #66685f;
    cursor: not-allowed;
  }

  .section {
    padding: 5rem 0;
    border-top: 1px solid #b9b8aa;
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.7fr);
    gap: 2rem;
    align-items: end;
    margin-bottom: 2.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .card,
  .offer,
  .notice {
    border: 1px solid #b9b8aa;
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.45);
  }

  .card {
    padding: 1.5rem;
  }

  .card.featured {
    grid-column: span 2;
  }

  .card .id {
    color: #6f766b;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
  }

  .card a {
    font-weight: 750;
  }

  .offer {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: 2rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    background: #203121;
    color: #f6f3e9;
  }

  .price {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 5rem;
    line-height: 1;
    text-align: right;
  }

  .muted {
    color: #74796f;
  }

  .offer .muted {
    color: #c8cec3;
  }

  .notice {
    padding: 1.25rem;
    border-left: 5px solid #c26b43;
  }

  .asset-detail {
    max-width: 840px;
    padding: 5rem 0;
  }

  .asset-detail h1 {
    font-size: clamp(3rem, 8vw, 6rem);
  }

  .facts {
    display: grid;
    gap: 0;
    margin: 3rem 0;
    border-top: 1px solid #b9b8aa;
  }

  .fact {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid #b9b8aa;
  }

  .fact dt {
    font-weight: 800;
  }

  .fact dd {
    margin: 0;
    line-height: 1.65;
  }

  footer {
    padding: 2rem 0 3rem;
    border-top: 1px solid #b9b8aa;
    color: #687266;
    font-size: 0.86rem;
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 4rem;
    }

    .section-heading,
    .offer,
    .fact {
      grid-template-columns: 1fr;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .card.featured {
      grid-column: auto;
    }

    .price {
      text-align: left;
    }

    .site-header > a:last-child {
      display: none;
    }
  }
</style>
