{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-self-funding-lab.local/dashboard/project.schema.json",
  "title": "AI Self-Funding Lab Portfolio Projects",
  "description": "The canonical list of project metric snapshots.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/project"
  },
  "$defs": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_name",
        "status",
        "created_at",
        "deployments",
        "indexed_pages",
        "visitors",
        "revenue",
        "cost",
        "profit",
        "roi",
        "data_window"
      ],
      "properties": {
        "project_name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Unique, stable kebab-case project slug."
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "validating",
            "building",
            "launched",
            "measuring",
            "scaling",
            "paused",
            "killed"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "deployments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deployment"
          }
        },
        "indexed_pages": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "visitors": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "revenue": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "cost": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "profit": {
          "type": ["number", "null"]
        },
        "roi": {
          "type": ["number", "null"]
        },
        "data_window": {
          "oneOf": [
            {
              "$ref": "#/$defs/dataWindow"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment",
        "url",
        "revision",
        "status",
        "deployed_at"
      ],
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["preview", "production"]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "revision": {
          "type": "string",
          "minLength": 7
        },
        "status": {
          "type": "string",
          "enum": ["success", "failed", "rolled_back"]
        },
        "deployed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "dataWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "timezone"],
      "properties": {
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
